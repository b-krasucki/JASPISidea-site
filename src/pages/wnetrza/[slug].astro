---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import GalleryItem from '@/components/gallery/GalleryItem.astro';
import Lightbox from '@/components/ui/Lightbox.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { tintStyle, interiorCategoryLabel, type InteriorCategory } from '@/lib/categories';
import { useTranslations, defaultLang, type Lang } from '@/i18n/utils';

export async function getStaticPaths() {
  const interiors = await getCollection('interiors');
  return interiors.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

const hasGallery = (data.gallery?.length ?? 0) > 0;

const workSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: data.title,
  dateCreated: String(data.year),
  creator: { '@type': 'Person', name: 'Katarzyna Krasucka' },
  description: data.description,
  ...(data.location ? { locationCreated: data.location } : {}),
  url: new URL(`/wnetrza/${entry.id}`, Astro.site).href,
};
---

<BaseLayout title={data.title} description={data.description}>
  <JsonLd slot="head" schema={workSchema} />
  <article class="container-content py-16">
    <a href="/wnetrza" class="text-[12px] uppercase tracking-[0.14em] text-ink-muted transition-colors hover:text-accent">
      <span aria-hidden="true">←</span> {t('interiorsPage.title')}
    </a>

    <header class="mt-8 grid grid-cols-1 gap-8 border-b border-line pb-12 md:grid-cols-[1fr_280px]">
      <div>
        <p class="eyebrow mb-4">{interiorCategoryLabel(data.category as InteriorCategory, lang)}</p>
        <h1 class="text-[clamp(32px,5vw,64px)]">{data.title}</h1>
        <p class="mt-6 max-w-xl text-[16px] leading-relaxed text-ink-muted">{data.description}</p>
      </div>
      <dl class="space-y-3 text-[13px] md:border-l md:border-line md:pl-8">
        <div class="flex justify-between gap-4">
          <dt class="uppercase tracking-[0.14em] text-ink-faint">{t('projectMeta.year')}</dt>
          <dd>{data.year}</dd>
        </div>
        {data.location && (
          <div class="flex justify-between gap-4">
            <dt class="uppercase tracking-[0.14em] text-ink-faint">{t('projectMeta.location')}</dt>
            <dd class="text-right">{data.location}</dd>
          </div>
        )}
        {data.scope && data.scope.length > 0 && (
          <div class="flex justify-between gap-4">
            <dt class="uppercase tracking-[0.14em] text-ink-faint">{t('projectMeta.scope')}</dt>
            <dd class="text-right">{data.scope.join(', ')}</dd>
          </div>
        )}
      </dl>
    </header>

    <!-- Cover / hero -->
    <div class="mt-12 overflow-hidden border border-line" style={`aspect-ratio:16/9; ${tintStyle('wnetrza')}`}>
      {data.cover ? (
        <Image src={data.cover} alt={data.alt ?? data.title} widths={[600, 1200, 1800]} sizes="100vw" class="h-full w-full object-cover" />
      ) : (
        <span class="work-placeholder flex h-full w-full items-start p-3 font-mono text-[11px] uppercase tracking-wide text-ink-faint" style={tintStyle('wnetrza')}>
          {t('common.photoSlot')} — {data.title}
        </span>
      )}
    </div>

    <div class="prose mt-12 max-w-2xl text-[16px] leading-relaxed text-ink-muted">
      <Content />
    </div>

    {hasGallery && (
      <div class="mt-12 grid grid-cols-1 gap-[clamp(18px,2.6vw,32px)] sm:grid-cols-2">
        {data.gallery!.map((img) => (
          <GalleryItem
            title={data.title}
            tint="wnetrza"
            cover={img.src}
            alt={img.alt}
            lightbox
            group={`interior-${entry.id}`}
            aspect="4/3"
          />
        ))}
      </div>
    )}
  </article>

  {hasGallery && <Lightbox />}
</BaseLayout>
