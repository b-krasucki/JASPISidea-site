---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { Image } from 'astro:assets';
import portrait from '@/assets/portrait.jpg';
import JsonLd from '@/components/seo/JsonLd.astro';
import { useTranslations, defaultLang, type Lang } from '@/i18n/utils';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Katarzyna Krasucka',
  alternateName: t('site.brand'),
  jobTitle: t('about.role'),
  url: new URL('/o-mnie', Astro.site).href,
  email: t('footer.email'),
  description: t('about.lead'),
};
---

<BaseLayout title={t('about.title')} description={t('about.lead')}>
  <JsonLd slot="head" schema={personSchema} />
  <article class="container-content py-16">
    <!-- Intro -->
    <header class="grid grid-cols-1 items-start gap-10 border-b border-line pb-16 md:grid-cols-[1fr_360px] md:gap-16" data-reveal>
      <div>
        <p class="eyebrow mb-4">{t('about.eyebrow')}</p>
        <h1 class="text-[clamp(36px,6vw,80px)] leading-[1.02]">{t('about.title')}</h1>
        <p class="mt-3 text-[13px] uppercase tracking-[0.14em] text-ink-muted">{t('about.role')}</p>
        <p class="mt-8 max-w-xl font-serif text-[clamp(20px,2.4vw,30px)] italic leading-snug text-ink">
          {t('about.lead')}
        </p>
      </div>
      <!-- Portret -->
      <div class="relative aspect-[4/5] overflow-hidden border border-line">
        <Image
          src={portrait}
          alt="Katarzyna Krasucka — projektantka wnętrz i artystka"
          widths={[400, 720]}
          sizes="(max-width: 768px) 100vw, 360px"
          loading="eager"
          class="h-full w-full object-cover"
        />
      </div>
    </header>

    <!-- Bio + podejście -->
    <div class="grid grid-cols-1 gap-12 py-16 md:grid-cols-2 md:gap-16">
      <div class="space-y-5 text-[16px] leading-relaxed text-ink-muted" data-reveal>
        <p>{t('about.bio1')}</p>
        <p>{t('about.bio2')}</p>
      </div>
      <div data-reveal>
        <h2 class="eyebrow mb-4">{t('about.approachHeading')}</h2>
        <p class="font-serif text-[clamp(22px,2.6vw,34px)] leading-snug">{t('about.approachText')}</p>
      </div>
    </div>

    <!-- CTA -->
    <div class="border-t border-line py-16 text-center" data-reveal>
      <Button href="/kontakt">{t('about.contactCta')}</Button>
    </div>
  </article>
</BaseLayout>
