---
import Logo from './Logo.astro';
import { useTranslations, defaultLang, type Lang } from '@/i18n/utils';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const year = new Date().getFullYear();

const nav = [
  { href: '/wnetrza', label: t('nav.interiors') },
  { href: '/sztuka', label: t('nav.art') },
  { href: '/o-mnie', label: t('nav.about') },
  { href: '/kontakt', label: t('nav.contact') },
];

const email = t('footer.email');
---

<footer class="mt-24 bg-surface">
  <div class="container-content grid grid-cols-1 gap-10 py-16 md:grid-cols-3">
    <!-- Kolumna 1: logo + opis -->
    <div class="max-w-xs">
      <Logo height={50} />
      <p class="mt-4 text-[14px] leading-relaxed text-ink-muted">{t('site.tagline')}</p>
    </div>

    <!-- Kolumna 2: nawigacja -->
    <nav aria-label={t('footer.navHeading')}>
      <h2 class="eyebrow mb-4">{t('footer.navHeading')}</h2>
      <ul class="space-y-2">
        {nav.map((item) => (
          <li>
            <a href={item.href} class="text-[14px] text-ink transition-colors hover:text-accent">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Kolumna 3: kontakt -->
    <div>
      <h2 class="eyebrow mb-4">{t('footer.contactHeading')}</h2>
      <ul class="space-y-2 text-[14px]">
        <li>
          <a href={`mailto:${email}`} class="text-ink transition-colors hover:text-accent">{email}</a>
        </li>
        <li>
          <a href="https://instagram.com" rel="noopener noreferrer" target="_blank" class="text-ink transition-colors hover:text-accent">
            {t('footer.instagram')}
          </a>
        </li>
        <li>
          <a href="https://etsy.com" rel="noopener noreferrer" target="_blank" class="text-ink transition-colors hover:text-accent">
            {t('footer.etsy')}
          </a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Pasek dolny: © + przełącznik języka -->
  <div class="border-t border-line">
    <div class="container-content flex flex-col items-start justify-between gap-2 py-5 text-[11px] uppercase tracking-[0.14em] text-ink-faint sm:flex-row sm:items-center">
      <span>© {year} {t('site.brand')}. {t('footer.rights')}</span>
      <span aria-label={t('lang.switchLabel')}>{t('lang.pl')} <span aria-hidden="true">/</span> {t('lang.da')}</span>
    </div>
  </div>
</footer>
