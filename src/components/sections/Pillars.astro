---
import { Image } from 'astro:assets';
import { useTranslations, defaultLang, type Lang } from '@/i18n/utils';
import wnetrzaImg from '../../content/photos/interiors/herbarium-realizacja/003.jpg';
import sztukaImg from '../../content/photos/artworks/meble/kiss-cover.jpg';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

const pillars = [
  {
    href: '/wnetrza',
    title: t('home.pillarInteriorsTitle'),
    desc: t('home.pillarInteriorsDesc'),
    descAccent: t('home.pillarInteriorsDescAccent'),
    caption: t('home.pillarInteriorsCaption'),
    img: wnetrzaImg,
    alt: 'Projekt wnętrza — Herbarium, realizacja',
  },
  {
    href: '/sztuka',
    title: t('home.pillarArtTitle'),
    desc: t('home.pillarArtDesc'),
    descAccent: t('home.pillarArtDescAccent'),
    caption: t('home.pillarArtCaption'),
    img: sztukaImg,
    alt: 'Mebel Kiss — JASPISidea',
  },
];
---

<section class="container-content py-[clamp(48px,10vh,120px)]">
  <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
    {pillars.map((p) => (
      <a href={p.href} class="group" data-reveal>
        <div class="relative aspect-square overflow-hidden">
          <Image
            src={p.img}
            alt={p.alt}
            widths={[600, 900]}
            sizes="(max-width: 768px) 100vw, 50vw"
            loading="lazy"
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
          />
          <span
            class="absolute bottom-4 left-4 text-[11px] tracking-wide text-ink-faint"
            aria-hidden="true"
          >{p.caption}</span>
        </div>
        <div class="mt-5 flex items-start justify-between gap-4">
          <div>
            <span class="font-serif text-[clamp(22px,2.6vw,38px)] leading-tight">{p.title}</span>
            <p class="mt-2 text-[14px] leading-relaxed text-ink-muted">
              {p.desc} <span class="text-accent">{p.descAccent}</span>
            </p>
          </div>
          <span aria-hidden="true" class="mt-1 shrink-0 text-[18px] text-ink-muted transition-transform duration-200 group-hover:translate-x-1">→</span>
        </div>
      </a>
    ))}
  </div>
</section>
