---
import { Image, getImage } from 'astro:assets';
import Badge from '@/components/ui/Badge.astro';
import { tintStyle, type TintKey } from '@/lib/categories';
import { useTranslations, defaultLang, type Lang } from '@/i18n/utils';

interface Props {
  title: string;
  meta?: string;
  tint: TintKey;
  cover?: ImageMetadata;
  alt?: string;
  isUV?: boolean;
  /** Link do podstrony (np. case wnętrza). Wyklucza się z lightbox. */
  href?: string;
  /** Otwiera w lightbox (galerie kategorii). */
  lightbox?: boolean;
  group?: string;
  /** aspect-ratio CSS, np. "4/3", "1/1", "3/4". */
  aspect?: string;
  /** Stała wysokość kontenera obrazu (nadpisuje aspect). Np. "clamp(280px,44vw,520px)". */
  imgHeight?: string;
  class?: string;
  /** URL do pliku mp4 w /public/videos/ — wyświetla odtwarzacz poniżej miniatury. */
  video?: string;
}

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

const {
  title, meta, tint, cover, alt, isUV = false,
  href, lightbox = false, group = 'default', aspect = '4/3', class: className = '',
  video, imgHeight,
} = Astro.props;

// Pełnowymiarowy URL do lightboxa (gdy jest realny obraz)
const lbSrc = cover ? (await getImage({ src: cover, width: 1600 })).src : undefined;

const Tag = video ? 'div' : (href ? 'a' : lightbox ? 'button' : 'div');
const slotLabel = `${t('common.photoSlot')} — ${title}`;
---

<figure class={`group ${className}`}>
  <Tag
    {...href ? { href } : {}}
    {...(!video && lightbox) ? {
      type: 'button',
      'data-lightbox': group,
      'data-lb-title': title,
      'data-lb-meta': meta ?? '',
      'data-lb-tint': tint,
      'data-lb-aspect': aspect,
      ...(lbSrc ? { 'data-lb-src': lbSrc } : {}),
    } : {}}
    class="relative block w-full overflow-hidden border border-line transition-colors duration-300 hover:border-accent"
    style={imgHeight ? `height:${imgHeight}` : `aspect-ratio:${aspect}`}
    aria-label={!video && (href || lightbox) ? title : undefined}
  >
    {cover ? (
      <Image
        src={cover}
        alt={alt ?? title}
        widths={[400, 800, 1200]}
        sizes="(max-width: 720px) 100vw, 50vw"
        loading="lazy"
        class="h-full w-full object-cover transition-opacity duration-300 group-hover:opacity-95"
      />
    ) : (
      <span class="work-placeholder absolute inset-0 block" style={tintStyle(tint)}>
        <span class="absolute left-3 top-3 font-mono text-[11px] uppercase tracking-wide text-ink-faint">
          {slotLabel}
        </span>
      </span>
    )}
    {isUV && <span class="absolute right-3 top-3"><Badge /></span>}
  </Tag>

  {(title || meta) && (
    <figcaption class="mt-3 flex items-baseline justify-between gap-4">
      <span class="font-serif text-[22px] leading-tight">{title}</span>
      {meta && <span class="shrink-0 text-[11px] uppercase tracking-[0.14em] text-ink-muted">{meta}</span>}
    </figcaption>
  )}
</figure>

{video && (
  <div class="mt-3 overflow-hidden border border-line">
    <video
      controls
      preload="none"
      class="w-full block bg-ink"
      {...(lbSrc ? { poster: lbSrc } : {})}
    >
      <source src={video} type="video/mp4" />
    </video>
  </div>
)}
